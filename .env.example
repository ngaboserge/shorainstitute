# ── Supabase (frontend) ─────────────────────────────────────────────────────
# Get these values from your Supabase dashboard: Settings > API
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Supabase (payment API server — never expose in frontend) ────────────────
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Site (card return URL + webhook base) ───────────────────────────────────
SITE_URL=http://localhost:3000
# Optional override for card return only (defaults to SITE_URL)
# XENTRIPAY_CARD_RETURN_URL_BASE=https://yourdomain.com

# ── XentriPay v2 ─────────────────────────────────────────────────────────────
# Keys: https://xentripay.com/settings/api-keys (or sandbox dashboard)
XENTRIPAY_API_KEY=a81f957023344b199177c7c9a68e9878
# Sandbox (default): https://test.xentripay.com — set to false for production
XENTRIPAY_SANDBOX=true
XENTRIPAY_BASE_URL=https://test.xentripay.com
XENTRIPAY_CHARGES_INCLUDED=true
# Dashboard webhooks are URL-only; leave empty unless XentriPay sends a secret header.
# XENTRIPAY_WEBHOOK_SECRET=

# ── Pricing (XentriPay collects RWF only; used to convert USD/EUR prices) ───
USD_TO_RWF_RATE=1463.5
EUR_TO_RWF_RATE=1590

# ── Frontend feature flags ───────────────────────────────────────────────────
# Card payments require activation in the XentriPay merchant dashboard.
VITE_CARD_PAYMENT_ENABLED=false

# IMPORTANT:
# 1. Copy this file to .env (don't commit .env to git!)
# 2. Replace the placeholder values with your actual credentials
# 3. Restart both dev servers after changes: npm run dev + npm run dev:api
